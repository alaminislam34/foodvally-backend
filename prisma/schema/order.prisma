model Order {
    id          String      @id @default(uuid())
    userId      String
    status      OrderStatus @default(PENDING)

    totalPrice  Float
    address     String
    phone       String

    isDeleted   Boolean     @default(false)
    deletedAt   DateTime?

    user        User        @relation(fields: [userId], references: [id])
    items       OrderItem[]

    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    @@index([userId])
    @@map("orders")
}